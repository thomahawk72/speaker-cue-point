{
  "name": "speaker-cue-point",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:client": "vite",
    "dev:server": "node --watch server.js",
