# Kopier til .env og sett verdier.

# --- Frontend (byggetid) ---
# Passord for klient-side innlogging. Bakes inn i bundelen ved build.
VITE_APP_PASSWORD=bytt-meg

# Samme hemmelighet som TRIGGER_API_KEY på server (påkrevd i nettleseren når server krever nøkkel).
# VITE_TRIGGER_API_KEY=

# --- Backend (runtime) ---
# Port Express-serveren lytter p\u00e5. Scalingo setter denne automatisk.
PORT=3001

# API-nøkkel for POST /api/trigger (header X-API-Key). Når satt, avvises kall uten gyldig nøkkel med 401.
# TRIGGER_API_KEY=

# n8n-webhook som /api/trigger proxier til.
N8N_WEBHOOK_URL=https://n8n.example.com/webhook/speaker-cue-point

# Hemmelig verdi som skal i auth-header mot n8n (samme som i n8n Header Auth «Value»).
# Uten denne sendes ingen auth-header. Ikke committ ekte verdier.
# N8N_AUTH_HEADER=
#
# HTTP-navn på den headeren (må matche n8n «Name», f.eks. N8N_AUTH_HEADER). Uten denne brukes Authorization.
# N8N_WEBHOOK_AUTH_HEADER_NAME=N8N_AUTH_HEADER

# Valgfritt: timeout i ms for kall mot n8n (default 10000)
# N8N_TIMEOUT_MS=10000
